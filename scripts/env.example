# .env.example
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# DATABASE_URL format for local dev (points to the db container):
#   postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB
#
# NEVER commit .env to git.

# ── Postgres (local dev — matches the db container in docker-compose.yml) ───
POSTGRES_DB=motostore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_something_strong

DATABASE_URL=postgresql://postgres:changeme_use_something_strong@db:5432/motostore

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_openssl_rand_output
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev uses the redis container. Keep these values as-is.
REDIS_HOST=redis
REDIS_PORT=6379
